# ============================================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================================

# Server Configuration
NODE_ENV=development
PORT=5001

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=attendance_tracker
DB_CONNECTION_LIMIT=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES (optional, for advanced setup)
# ============================================================================

# API Base URL - Backend server address
VITE_API_BASE_URL=http://localhost:5001/api

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. Copy this file to .env in both backend and frontend folders
#    cp .env.example .env
#
# 2. Update database credentials:
#    - DB_USER: Your MySQL username (default: root)
#    - DB_PASSWORD: Your MySQL password
#    - DB_NAME: Database name (you may need to create it first)
#
# 3. Create the database:
#    mysql -u root -p
#    CREATE DATABASE attendance_tracker;
#    USE attendance_tracker;
#    SOURCE database/schema.sql;
#
# 4. Update JWT_SECRET in production:
#    Generate a strong random key (min 32 characters)
#    Example: openssl rand -base64 32
#
# 5. Change PORT if default 5000 is already in use
#
# 6. For production:
#    - Change NODE_ENV to 'production'
#    - Use strong JWT_SECRET
#    - Use secure database credentials
#    - Set proper CORS origins
#
# ============================================================================

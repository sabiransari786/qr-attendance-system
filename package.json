{
  "name": "attendance-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "QR-Based Attendance Tracking System",
  "scripts": {
    "install:backend": "npm install --prefix backend",
    "install:frontend": "npm install --prefix frontend",
    "postinstall": "npm run install:backend && npm run install:frontend",
    "backend": "npm start --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --prefix frontend",
    "build:prod": "cd frontend && npm run build",
    "preview": "npm run preview --prefix frontend",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:vercel": "cd frontend && vercel --prod",
    "deploy:railway": "railway up"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "mysql2": "^3.18.2",
    "vite": "^7.3.1"
  }
}

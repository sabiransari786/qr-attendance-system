# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env in production and update all values

# Server Configuration
NODE_ENV=production
PORT=5001

# Your production domain (no trailing slash)
FRONTEND_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Database Configuration (Use your production database)
DB_HOST=your-production-db-host
DB_PORT=3306
DB_USER=your_production_db_user
DB_PASSWORD=your_secure_production_password
DB_NAME=attendance_tracker_prod
DB_CONNECTION_LIMIT=20

# JWT Configuration - CHANGE THIS IN PRODUCTION!
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRY=24h

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=12

# Email Configuration (for OTP/Password Reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# Create frontend/.env.production with these:

# VITE_API_BASE_URL=https://api.yourdomain.com/api
